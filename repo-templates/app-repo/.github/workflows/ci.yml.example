name: app-ci

on:
  pull_request:
  push:
    branches:
      - main

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up runtime
        run: echo "Install project runtime here"

      - name: Lint
        run: echo "Run lint command here"

      - name: Test
        run: echo "Run test command here"

      - name: Build image
        run: echo "Build image with placeholder registry reference"

      - name: Scan image
        run: echo "Run container and dependency scanning here"
