name: reusable-security-scan

on:
  workflow_call:
    inputs:
      image-name:
        required: true
        type: string
      upload-to-defectdojo:
        required: false
        type: boolean
        default: false
    secrets:
      REGISTRY_HOST:
        required: false
      DEFECTDOJO_URL:
        required: false
      DEFECTDOJO_API_KEY:
        required: false

jobs:
  scan:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      security-events: write
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Secret scan
        uses: gitleaks/gitleaks-action@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: SAST
        uses: semgrep/semgrep-action@v1
        with:
          config: p/ci

      - name: Filesystem vulnerability scan
        uses: aquasecurity/trivy-action@master
        with:
          scan-type: fs
          scan-ref: .
          format: sarif
          output: trivy-fs.sarif
          severity: CRITICAL,HIGH
          exit-code: "1"

      - name: Build image
        run: docker build -t "${{ inputs.image-name }}:${{ github.sha }}" .

      - name: Image vulnerability scan
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: ${{ inputs.image-name }}:${{ github.sha }}
          format: sarif
          output: trivy-image.sarif
          severity: CRITICAL,HIGH
          exit-code: "1"

      - name: Generate SBOM
        run: trivy image --format cyclonedx --output sbom.cdx.json "${{ inputs.image-name }}:${{ github.sha }}"

      - name: Upload scan artifacts
        uses: actions/upload-artifact@v4
        with:
          name: security-reports
          path: |
            trivy-fs.sarif
            trivy-image.sarif
            sbom.cdx.json

      - name: Import image scan into DefectDojo
        if: inputs.upload-to-defectdojo
        env:
          DEFECTDOJO_URL: ${{ secrets.DEFECTDOJO_URL }}
          DEFECTDOJO_API_KEY: ${{ secrets.DEFECTDOJO_API_KEY }}
          DEFECTDOJO_PRODUCT_NAME: ${{ github.repository }}
          DEFECTDOJO_ENGAGEMENT_NAME: ci-${{ github.ref_name }}
        run: |
          ./defectdojo/scripts/import-scan.sh \
            --scan-type "Trivy Scan" \
            --report-file trivy-image.sarif \
            --branch "${{ github.ref_name }}" \
            --commit "${{ github.sha }}"
