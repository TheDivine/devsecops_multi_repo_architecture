name: app-ci

on:
  pull_request:
  push:
    branches:
      - main

jobs:
  validate:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      security-events: write
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install ruff pytest

      - name: Lint
        run: ruff check .

      - name: Test
        run: pytest -q

      - name: Build image
        run: docker build -t "${{ vars.IMAGE_NAME || 'starter-app' }}:${{ github.sha }}" .

      - name: Secret scanning - Gitleaks
        uses: gitleaks/gitleaks-action@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Filesystem scan - Trivy
        uses: aquasecurity/trivy-action@master
        with:
          scan-type: fs
          scan-ref: .
          format: sarif
          output: trivy-fs.sarif
          severity: CRITICAL,HIGH
          exit-code: "1"

      - name: Image scan - Trivy
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: ${{ vars.IMAGE_NAME || 'starter-app' }}:${{ github.sha }}
          format: sarif
          output: trivy-image.sarif
          severity: CRITICAL,HIGH
          exit-code: "1"

      - name: Generate SBOM
        run: trivy image --format cyclonedx --output sbom.cdx.json "${{ vars.IMAGE_NAME || 'starter-app' }}:${{ github.sha }}"

      - name: Upload security reports
        uses: actions/upload-artifact@v4
        with:
          name: security-reports
          path: |
            trivy-fs.sarif
            trivy-image.sarif
            sbom.cdx.json
