kind: pipeline
type: docker
name: app-ci

steps:
  - name: lint
    image: alpine:latest
    commands:
      - echo "Run lint command here"

  - name: test
    image: alpine:latest
    commands:
      - echo "Run test command here"

  - name: build-image
    image: alpine:latest
    commands:
      - echo "Build image with placeholder registry reference"

  - name: scan
    image: alpine:latest
    commands:
      - echo "Run security scans here"
