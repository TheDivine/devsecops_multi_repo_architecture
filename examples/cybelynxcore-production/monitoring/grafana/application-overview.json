{
  "title": "Cybelynxcore API Overview",
  "tags": ["cybelynxcore", "practice", "production-like"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"cybelynxcore-production\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pod Restarts",
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"cybelynxcore-production\"}[15m]))"
        }
      ]
    }
  ]
}
